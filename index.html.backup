<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>銓宏國際 - 產品提案系統</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@300;400;500;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --primary: #1a365d;
            --primary-light: #2c5282;
            --secondary: #ed8936;
            --accent: #38a169;
            --bg-light: #f7fafc;
            --text-dark: #2d3748;
            --text-muted: #718096;
            --border: #e2e8f0;
            --shadow: 0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -1px rgba(0,0,0,0.06);
            --shadow-lg: 0 20px 25px -5px rgba(0,0,0,0.1), 0 10px 10px -5px rgba(0,0,0,0.04);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Noto Sans TC', sans-serif;
            background: var(--bg-light);
            color: var(--text-dark);
            line-height: 1.6;
        }
        
        /* Header */
        .header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
            padding: 2rem 0;
            box-shadow: var(--shadow-lg);
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 1.5rem;
        }
        
        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }
        
        .logo {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        
        .logo-icon {
            width: 50px;
            height: 50px;
            background: white;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--primary);
            font-size: 1.5rem;
            font-weight: bold;
        }
        
        .logo-text h1 {
            font-size: 1.5rem;
            font-weight: 700;
        }
        
        .logo-text p {
            font-size: 0.875rem;
            opacity: 0.9;
        }
        
        .project-info {
            text-align: right;
        }
        
        .project-code {
            background: rgba(255,255,255,0.2);
            padding: 0.5rem 1rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 500;
        }
        
        /* Main Content */
        .main {
            padding: 2rem 0;
        }
        
        .section-title {
            font-size: 1.5rem;
            font-weight: 700;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        
        .section-title i {
            color: var(--secondary);
        }
        
        /* Project Summary Card */
        .summary-card {
            background: white;
            border-radius: 16px;
            padding: 1.5rem;
            margin-bottom: 2rem;
            box-shadow: var(--shadow);
        }
        
        .summary-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
        }
        
        .summary-item {
            padding: 1rem;
            background: var(--bg-light);
            border-radius: 12px;
            border-left: 4px solid var(--primary);
        }
        
        .summary-item label {
            font-size: 0.75rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        
        .summary-item p {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-dark);
            margin-top: 0.25rem;
        }
        
        /* Products Grid */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 1.5rem;
        }
        
        .product-card {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: var(--shadow);
            transition: transform 0.3s, box-shadow 0.3s;
            position: relative;
        }
        
        .product-card:hover {
            transform: translateY(-4px);
            box-shadow: var(--shadow-lg);
        }
        
        .product-header {
            background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
            color: white;
            padding: 1.25rem;
            position: relative;
        }
        
        .product-number {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background: rgba(255,255,255,0.2);
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.875rem;
        }
        
        .product-type {
            font-size: 0.75rem;
            opacity: 0.9;
            margin-bottom: 0.25rem;
        }
        
        .product-name {
            font-size: 1.25rem;
            font-weight: 700;
        }
        
        .product-body {
            padding: 1.5rem;
        }
        
        .info-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--border);
        }
        
        .info-row:last-child {
            border-bottom: none;
        }
        
        .info-label {
            font-size: 0.875rem;
            color: var(--text-muted);
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .info-value {
            font-weight: 600;
            color: var(--text-dark);
        }
        
        .info-value.price {
            color: var(--accent);
            font-size: 1.125rem;
        }
        
        .product-features {
            background: var(--bg-light);
            padding: 1rem;
            border-radius: 8px;
            margin: 1rem 0;
        }
        
        .product-features h4 {
            font-size: 0.875rem;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
        }
        
        .product-features p {
            font-size: 0.9375rem;
            color: var(--text-dark);
        }
        
        .supplier-tag {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            background: #ebf8ff;
            color: #2b6cb0;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            font-size: 0.875rem;
            font-weight: 500;
        }
        
        .interest-btn {
            width: 100%;
            padding: 1rem;
            background: var(--secondary);
            color: white;
            border: none;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.5rem;
        }
        
        .interest-btn:hover {
            background: #dd6b20;
        }
        
        .interest-btn.active {
            background: var(--accent);
        }
        
        /* Comparison Table */
        .comparison-section {
            margin-top: 2rem;
        }
        
        .comparison-table {
            background: white;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: var(--shadow);
            overflow-x: auto;
        }
        
        table {
            width: 100%;
            border-collapse: collapse;
        }
        
        th {
            background: var(--primary);
            color: white;
            padding: 1rem;
            text-align: left;
            font-weight: 600;
            font-size: 0.875rem;
        }
        
        td {
            padding: 1rem;
            border-bottom: 1px solid var(--border);
            font-size: 0.9375rem;
        }
        
        tr:hover {
            background: var(--bg-light);
        }
        
        .rating {
            color: var(--secondary);
        }
        
        /* Footer */
        .footer {
            background: var(--primary);
            color: white;
            padding: 2rem 0;
            margin-top: 3rem;
        }
        
        .footer-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 1rem;
        }
        
        .footer-info p {
            font-size: 0.875rem;
            opacity: 0.9;
        }
        
        .footer-actions {
            display: flex;
            gap: 1rem;
        }
        
        .btn {
            padding: 0.75rem 1.5rem;
            border-radius: 8px;
            font-size: 0.875rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            border: none;
        }
        
        .btn-primary {
            background: var(--secondary);
            color: white;
        }
        
        .btn-primary:hover {
            background: #dd6b20;
        }
        
        .btn-secondary {
            background: rgba(255,255,255,0.2);
            color: white;
        }
        
        .btn-secondary:hover {
            background: rgba(255,255,255,0.3);
        }
        
        /* Responsive */
        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                text-align: center;
            }
            
            .project-info {
                text-align: center;
            }
            
            .products-grid {
                grid-template-columns: 1fr;
            }
            
            .comparison-table {
                font-size: 0.875rem;
            }
            
            th, td {
                padding: 0.75rem 0.5rem;
            }
        }
        
        /* Loading State */
        .loading {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 3rem;
        }
        
        .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid var(--border);
            border-top-color: var(--primary);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Toast Notification */
        .toast {
            position: fixed;
            bottom: 2rem;
            right: 2rem;
            background: var(--accent);
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 8px;
            box-shadow: var(--shadow-lg);
            display: none;
            align-items: center;
            gap: 0.75rem;
            z-index: 1000;
        }
        
        .toast.show {
            display: flex;
            animation: slideIn 0.3s ease;
        }
        
        @keyframes slideIn {
            from {
                transform: translateX(100%);
                opacity: 0;
            }
            to {
                transform: translateX(0);
                opacity: 1;
            }
        }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="header">
        <div class="container">
            <div class="header-content">
                <div class="logo">
                    <div class="logo-icon">銓</div>
                    <div class="logo-text">
                        <h1>銓宏國際有限公司</h1>
                        <p>Chuanhung International - 專業禮贈品定制</p>
                    </div>
                </div>
                <div class="project-info">
                    <div class="project-code">
                        <i class="fas fa-folder-open"></i> 專案編號：A0015-260320
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Main Content -->
    <main class="main">
        <div class="container">
            <!-- Project Summary -->
            <div class="summary-card">
                <div class="summary-grid">
                    <div class="summary-item">
                        <label>客戶名稱</label>
                        <p>易集</p>
                    </div>
                    <div class="summary-item">
                        <label>聯絡人</label>
                        <p>Rebecca</p>
                    </div>
                    <div class="summary-item">
                        <label>預計數量</label>
                        <p>12,000 - 20,000 PCS</p>
                    </div>
                    <div class="summary-item">
                        <label>目標成本</label>
                        <p>RMB 3-3.5 /個</p>
                    </div>
                    <div class="summary-item">
                        <label>客戶預算</label>
                        <p>RMB 5 /個</p>
                    </div>
                    <div class="summary-item">
                        <label>參考風格</label>
                        <p>可愛/療癒風格</p>
                    </div>
                </div>
            </div>

            <!-- Products Section -->
            <h2 class="section-title">
                <i class="fas fa-gift"></i>
                產品提案品項
            </h2>
            
            <div class="products-grid" id="productsContainer">
                <!-- Products will be loaded here -->
                <div class="loading">
                    <div class="spinner"></div>
                </div>
            </div>

            <!-- Comparison Table -->
            <div class="comparison-section">
                <h2 class="section-title">
                    <i class="fas fa-table"></i>
                    綜合比較表
                </h2>
                <div class="comparison-table">
                    <table>
                        <thead>
                            <tr>
                                <th>品項</th>
                                <th>成本</th>
                                <th>報價建議</th>
                                <th>毛利</th>
                                <th>供應商</th>
                                <th>交期</th>
                                <th>推薦指數</th>
                            </tr>
                        </thead>
                        <tbody id="comparisonBody">
                            <!-- Data will be loaded here -->
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <div class="container">
            <div class="footer-content">
                <div class="footer-info">
                    <p><strong>銓宏國際有限公司</strong></p>
                    <p>新北市三重區溪尾街41號B1 | TEL: 02-89881163</p>
                </div>
                <div class="footer-actions">
                    <button class="btn btn-secondary" onclick="exportToPDF()">
                        <i class="fas fa-file-pdf"></i> 匯出 PDF
                    </button>
                    <button class="btn btn-primary" onclick="submitFeedback()">
                        <i class="fas fa-paper-plane"></i> 提交回饋
                    </button>
                </div>
            </div>
        </div>
    </footer>

    <!-- Toast Notification -->
    <div class="toast" id="toast">
        <i class="fas fa-check-circle"></i>
        <span id="toastMessage">已標記感興趣</span>
    </div>

    <script>
        // Product Data
        const products = [
            {
                id: 1,
                type: "保溫袋/便當袋",
                name: "療癒系鋁箔保溫便當袋",
                price: "RMB 3.2-3.8",
                specs: "21×15×22cm / 12安帆布+3mm鋁箔珍珠棉",
                features: "外層帆布可全彩印刷，鋁箔內襯保溫保冷3-4小時，立體造型容量大",
                reason: "符合客戶參考品項，市場接受度高，印刷面積大適合品牌露出",
                supplier: "本道紙塑-陳先生",
                quote: "RMB 4.8-5.2",
                margin: "25-30%",
                leadTime: "25-30天",
                rating: "⭐⭐⭐⭐⭐"
            },
            {
                id: 2,
                type: "收納包/餐具袋",
                name: "質感帆布餐具收納包",
                price: "RMB 2.8-3.3",
                specs: "25×8cm（展開）/ 8安帆布+內裡滌綸",
                features: "捲軸式設計，內含餐具固定格層，可搭配環保餐具組合",
                reason: "ESG趨勢熱門品項，企業禮贈接受度高，與保溫袋可組合為套組",
                supplier: "本道紙塑-陳先生",
                quote: "RMB 4.5-5.0",
                margin: "35-40%",
                leadTime: "20-25天",
                rating: "⭐⭐⭐⭐"
            },
            {
                id: 3,
                type: "保冷袋/飲料提袋",
                name: "手搖飲專用保冷提袋",
                price: "RMB 2.5-3.0",
                specs: "底10×10cm，高18cm / 潛水布或帆布+鋁箔",
                features: "台灣手搖飲文化熱門周邊，鋁箔內襯可保冷2-3小時",
                reason: "台灣市場熱門，年輕族群喜愛，單價低可大量發送",
                supplier: "1688溫州工廠",
                quote: "RMB 4.0-4.8",
                margin: "35-40%",
                leadTime: "20-25天",
                rating: "⭐⭐⭐⭐"
            },
            {
                id: 4,
                type: "帆布袋/托特包",
                name: "厚磅帆布托特包（有底有側）",
                price: "RMB 3.5-4.2",
                specs: "35×12×28cm / 12安帆布 / 內袋+磁扣設計",
                features: "經典實用款，12安厚磅帆布質感佳，雙面可印刷",
                reason: "最通用的禮贈品，各年齡層都適用，使用頻率高品牌曝光度佳",
                supplier: "本道紙塑-陳先生",
                quote: "RMB 5.5-6.5",
                margin: "30-35%",
                leadTime: "20-25天",
                rating: "⭐⭐⭐⭐"
            },
            {
                id: 5,
                type: "束口袋/收納袋",
                name: "質感帆布束口袋（大+小組合）",
                price: "RMB 3.0-3.5",
                specs: "大袋20×25cm + 小袋12×15cm / 8安帆布",
                features: "大小袋組合CP值高，束口設計方便，可分開或組合使用",
                reason: "一組兩個視覺價值感高，成本控制在目標內，印刷面積充足",
                supplier: "本道紙塑-陳先生",
                quote: "RMB 5.0-6.0",
                margin: "35-40%",
                leadTime: "20-25天",
                rating: "⭐⭐⭐⭐⭐"
            }
        ];

        // Load Products
        function loadProducts() {
            const container = document.getElementById('productsContainer');
            container.innerHTML = products.map(product => `
                <div class="product-card" data-id="${product.id}">
                    <div class="product-header">
                        <div class="product-number">${product.id}</div>
                        <div class="product-type">${product.type}</div>
                        <div class="product-name">${product.name}</div>
                    </div>
                    <div class="product-body">
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-tag"></i> 參考單價</span>
                            <span class="info-value price">${product.price}</span>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-ruler"></i> 產品規格</span>
                            <span class="info-value">${product.specs}</span>
                        </div>
                        <div class="product-features">
                            <h4><i class="fas fa-star"></i> 產品特色</h4>
                            <p>${product.features}</p>
                        </div>
                        <div class="product-features">
                            <h4><i class="fas fa-check-circle"></i> 為何選這個</h4>
                            <p>${product.reason}</p>
                        </div>
                        <div class="info-row">
                            <span class="info-label"><i class="fas fa-building"></i> 手中對象</span>
                            <span class="supplier-tag">
                                <i class="fas fa-handshake"></i> ${product.supplier}
                            </span>
                        </div>
                    </div>
                    <button class="interest-btn" onclick="toggleInterest(${product.id})">
                        <i class="far fa-heart"></i> 標記感興趣
                    </button>
                </div>
            `).join('');
        }

        // Load Comparison Table
        function loadComparison() {
            const tbody = document.getElementById('comparisonBody');
            tbody.innerHTML = products.map(product => `
                <tr>
                    <td><strong>${product.name}</strong></td>
                    <td>${product.price}</td>
                    <td>${product.quote}</td>
                    <td>${product.margin}</td>
                    <td>${product.supplier}</td>
                    <td>${product.leadTime}</td>
                    <td class="rating">${product.rating}</td>
                </tr>
            `).join('');
        }

        // Toggle Interest
        function toggleInterest(productId) {
            const card = document.querySelector(`[data-id="${productId}"]`);
            const btn = card.querySelector('.interest-btn');
            const isActive = btn.classList.contains('active');
            
            if (isActive) {
                btn.classList.remove('active');
                btn.innerHTML = '<i class="far fa-heart"></i> 標記感興趣';
                showToast('已取消標記');
            } else {
                btn.classList.add('active');
                btn.innerHTML = '<i class="fas fa-heart"></i> 已標記感興趣';
                showToast('已標記感興趣，我們會優先準備此品項的樣品');
                
                // Save to localStorage (simulating database)
                saveInterest(productId);
            }
        }

        // Save Interest (simulating database)
        function saveInterest(productId) {
            let interests = JSON.parse(localStorage.getItem('interestedProducts') || '[]');
            if (!interests.includes(productId)) {
                interests.push(productId);
                localStorage.setItem('interestedProducts', JSON.stringify(interests));
            }
        }

        // Show Toast
        function showToast(message) {
            const toast = document.getElementById('toast');
            const toastMessage = document.getElementById('toastMessage');
            toastMessage.textContent = message;
            toast.classList.add('show');
            
            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // Export to PDF
        function exportToPDF() {
            showToast('正在生成 PDF...');
            setTimeout(() => {
                window.print();
            }, 1000);
        }

        // Submit Feedback
        function submitFeedback() {
            const interested = JSON.parse(localStorage.getItem('interestedProducts') || '[]');
            if (interested.length === 0) {
                showToast('請先標記感興趣的品項');
                return;
            }
            
            const productNames = interested.map(id => {
                const product = products.find(p => p.id === id);
                return product ? product.name : '';
            }).filter(Boolean);
            
            showToast(`已提交回饋：感興趣品項 - ${productNames.join(', ')}`);
            
            // Here you would typically send data to Supabase
            console.log('Submitting to database:', {
                projectId: 'A0015-260320',
                interestedProducts: interested,
                timestamp: new Date().toISOString()
            });
        }

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            loadProducts();
            loadComparison();
        });
    </script>
</body>
</html>
